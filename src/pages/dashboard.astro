---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import type { Plan } from "@/types/database";
import { DeletePlanButton } from "@/components/DeletePlanButton";
import { GeneratePlanButton } from "@/components/GeneratePlanButton";
import { OPENROUTER_API_KEY } from "astro:env/server";

const supabase = createClient(Astro.request.headers, Astro.cookies);
let plans: Plan[] = [];

if (supabase) {
  const { data } = await supabase.from("plans").select("*").order("created_at", { ascending: false });
  plans = (data ?? []) as Plan[];
}

const keyMissing = !OPENROUTER_API_KEY;

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-6 text-white">
    <div class="mx-auto max-w-3xl">
      <div class="mb-8 flex items-center justify-between">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          My Plans
        </h1>
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            Sign out
          </button>
        </form>
      </div>

      {
        plans.length === 0 ? (
          <div class="rounded-2xl border border-white/10 bg-white/10 p-12 text-center backdrop-blur-xl">
            <p class="mb-6 text-blue-100/60">No plans yet — generate your first training plan.</p>
            <GeneratePlanButton disabled={keyMissing} client:only="react" />
          </div>
        ) : (
          <div class="flex flex-col gap-4">
            <GeneratePlanButton
              label="+ Generate plan"
              disabled={keyMissing}
              className="self-start"
              client:only="react"
            />
            {plans.map((plan) => (
              <div data-plan-id={plan.id} class="rounded-2xl border border-white/10 bg-white/10 backdrop-blur-xl">
                <a href={`/plans/${plan.id}`} class="block p-6 transition-colors hover:bg-white/10">
                  <div class="flex items-start justify-between gap-4">
                    <p class="text-lg font-semibold">{plan.name}</p>
                    <span
                      class:list={[
                        "shrink-0 rounded-full px-3 py-0.5 text-xs font-medium",
                        plan.goal === "speed" ? "bg-blue-500/30 text-blue-200" : "bg-green-500/30 text-green-200",
                      ]}
                    >
                      {plan.goal === "speed" ? "Speed" : "Distance"}
                    </span>
                  </div>
                  <p class="mt-2 text-sm text-blue-100/50">{formatDate(plan.created_at)}</p>
                </a>
                <div class="border-t border-white/5 px-6 py-3">
                  <DeletePlanButton planId={plan.id} client:load />
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>
</Layout>
